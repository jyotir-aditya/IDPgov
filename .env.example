# Copy to .env and fill in
GEMINI_API_KEY=
SHEET_ID=
API_TOKEN=
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
AI_PROVIDER=gemini
SL_NO_PREFIX=BEP/UP

# Cloudflare R2 (PDF storage) — from the R2 bucket's "Manage API tokens" page
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Bucket's public URL (Settings -> Public access), e.g. https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=
